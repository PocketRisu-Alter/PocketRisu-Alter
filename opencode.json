{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [".opencode/AGENTS.md"],
  "agent": {
    "chat": {
      "mode": "primary",
      "description": "일반 대화용 에이전트",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "edit": "ask",
        "bash": "ask"
      }
    }
  },
  "permission": {
    "skill": {
      "caveman": "allow",
      "caveman-commit": "allow",
      "caveman-review": "allow",
      "caveman-help": "allow",
      "caveman-compress": "allow"
    }
  }
}
