+      const key = await cryptoApi.importKey(
+        'pkcs8',
+        pemToArrayBuffer(privateKeyPem),
+        { name: 'RSASSA-PKCS1-v1_5', hash: 'SHA-256' },
+        false,
+        ['sign'],
