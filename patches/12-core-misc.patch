+/* ---- AlterRisu motion & performance helpers ---- */
+
+/* Micro-interactions: color and transform transitions for common interactive
+   elements. Use transform/opacity where possible to stay on the compositor. */
+button,
+[role="button"],
+a,
+input,
+textarea,
+select,
+.chat-message-container,
+.sidebar-item,
+.menu-item {
+  transition-property: color, background-color, border-color, box-shadow, opacity, transform;
+  transition-duration: var(--dur-fast);
+  transition-timing-function: var(--ease-out);
+}
+
+button:active,
+[role="button"]:active,
+a:active {
+  transform: scale(0.98);
+}
+
+/* Respect reduced motion system preference. */
+@media (prefers-reduced-motion: reduce) {
+  *,
+  *::before,
+  *::after {
+    animation-duration: 0.01ms !important;
+    animation-iteration-count: 1 !important;
+    transition-duration: 0.01ms !important;
+    scroll-behavior: auto !important;
+  }
+}
+
+/* Prevent native image drag ghosting on mobile/touch browsers. Images and
+   media should not follow the finger during scroll or swipe gestures. */
+img,
+video,
+audio,
+canvas,
+svg {
+  -webkit-user-drag: none;
+  -khtml-user-drag: none;
+  -moz-user-drag: none;
+  -o-user-drag: none;
+  user-drag: none;
+  -webkit-touch-callout: none;
+  user-select: none;
+  -webkit-user-select: none;
+  -moz-user-select: none;
+  -ms-user-select: none;
+}
+
+/* mobile-drag-drop polyfill creates a drag image that follows the finger.
+   Keep the reorder behavior but hide the visual ghost so images don't appear
+   to stick to the touch point during scroll or accidental long-press. */
+.dnd-poly-drag-image,
+.dnd-poly-drag-image * {
+  opacity: 0 !important;
+  visibility: hidden !important;
+}
+
+/* Allow selectable text in inputs and editable/chat areas while still
+   blocking native drag previews. */
+input,
+textarea,
+[contenteditable="true"],
+.chattext,
+.prose {
+  user-select: text;
+  -webkit-user-select: text;
+}
+
+/* Contain paint for scrollable lists and chat messages to reduce repaints. */
+.scroll-container,
+.chat-scroll,
+.chat-message-container {
+  content-visibility: auto;
+  contain-intrinsic-size: 0 56px;
+}
+
+/* Lazy-loaded images should fade in instead of popping. */
+img[loading="lazy"] {
+  opacity: 0;
+  transition: opacity var(--dur-base) var(--ease-out);
+}
+
+img[loading="lazy"].loaded,
+img[loading="lazy"]:not([src=""]) {
+  opacity: 1;
+}
+
+/* Sidebar slide transition. */
+.sidebar-enter {
+  transform: translateX(-100%);
+  opacity: 0;
+}
+
+.sidebar-enter-active {
+  transform: translateX(0);
+  opacity: 1;
+  transition: transform var(--dur-base) var(--ease-out), opacity var(--dur-base) var(--ease-out);
+}
+
+.sidebar-exit {
+  transform: translateX(0);
+  opacity: 1;
+}
+
+.sidebar-exit-active {
+  transform: translateX(-100%);
+  opacity: 0;
+  transition: transform var(--dur-base) var(--ease-out), opacity var(--dur-base) var(--ease-out);
+}
+
+/* Dialog/modal backdrop and panel transitions. */
+.modal-backdrop {
+  opacity: 0;
+  transition: opacity var(--dur-base) var(--ease-out);
+}
+
+.modal-backdrop.open {
+  opacity: 1;
+}
+
+.modal-panel {
+  transform: scale(0.96);
+  opacity: 0;
+  transition: transform var(--dur-base) var(--ease-out), opacity var(--dur-base) var(--ease-out);
+}
+
+.modal-panel.open {
+  transform: scale(1);
+  opacity: 1;
+}
+
+/* Toast / notification slide-in. */
+.toast-enter {
+  transform: translateY(-8px);
+  opacity: 0;
+}
+
+.toast-enter-active {
+  transform: translateY(0);
+  opacity: 1;
+  transition: transform var(--dur-fast) var(--ease-out), opacity var(--dur-fast) var(--ease-out);
+}
+
+/* Composer expand / collapse micro motion. */
+.composer {
+  transition: max-height var(--dur-base) var(--ease-out), padding var(--dur-base) var(--ease-out);
+}
+
+/* Chat message appear animation. */
+@keyframes message-enter {
+  from {
+    opacity: 0;
+    transform: translateY(6px);
+  }
+  to {
+    opacity: 1;
+    transform: translateY(0);
+  }
+}
+
+.chat-message-appear {
+  animation: message-enter var(--dur-base) var(--ease-out) forwards;
+}
+
+/* Chat bubble customization
+   ---------------------------------------------------------------------------
+   Activated by `data-chat-bubble-mode="bubble"` or `"glass"` on <html>.
+   Strips the default card background so the .chattext bubble stands alone.
+   Colors fall back to the active theme's `--msg-*` tokens when the user
+   hasn't overridden them. */
+:root[data-chat-bubble-mode="bubble"] .chat-message-container .bg-bgcolor.sm\:rounded-lg,
+:root[data-chat-bubble-mode="glass"]  .chat-message-container .bg-bgcolor.sm\:rounded-lg {
+  background-color: transparent !important;
+  padding: 0.5rem !important;
+  border-radius: 0 !important;
+}
+
+/* Shared bubble shape: inline-block with rounded padding */
+:root[data-chat-bubble-mode="bubble"] .chat-message-container .chattext,
+:root[data-chat-bubble-mode="glass"]  .chat-message-container .chattext {
+  display: inline-block;
+  vertical-align: top;
+  width: fit-content;
+  max-width: 100%;
+  border-radius: var(--radius-md, 10px);
+  padding: 0.5rem 0.75rem;
+}
+
+/* ── bubble mode ── */
+:root[data-chat-bubble-mode="bubble"] .chat-message-container[data-role="user"] .chattext {
+  background-color: var(--chat-user-bg, var(--msg-user-bg, var(--bg-surface)));
+  border: 1px solid var(--chat-user-border, var(--msg-user-border, var(--border-subtle)));
+}
+:root[data-chat-bubble-mode="bubble"] .chat-message-container[data-role="char"] .chattext {
+  background-color: var(--chat-char-bg, var(--msg-char-bg, var(--bg-raised)));
+  border: 1px solid var(--chat-char-border, var(--msg-char-border, var(--border-subtle)));
+}
+
+/* ── glass mode ── */
+:root[data-chat-bubble-mode="glass"] .chat-message-container[data-role="user"] .chattext {
+  background-color: color-mix(in srgb, var(--chat-user-bg, var(--msg-user-bg, var(--bg-surface))) 55%, transparent);
+  border: 1px solid var(--chat-user-border, var(--msg-user-border, var(--border-subtle)));
+  backdrop-filter: blur(8px);
+  -webkit-backdrop-filter: blur(8px);
+}
+:root[data-chat-bubble-mode="glass"] .chat-message-container[data-role="char"] .chattext {
+  background-color: color-mix(in srgb, var(--chat-char-bg, var(--msg-char-bg, var(--bg-raised))) 38%, transparent);
+  border: 1px solid var(--chat-char-border, var(--msg-char-border, var(--border-subtle)));
+  backdrop-filter: blur(8px);
+  -webkit-backdrop-filter: blur(8px);
+}
+
+/* Em (italic emphasis) recolor — applied regardless of bubble mode when set */
+.chat-message-container .chattext em {
+  color: var(--chat-em-color, var(--msg-em-color, inherit));
+}
+
+/* Streaming border indicator (when chat marks itself streaming, downstream
+   themes may add the `.is-streaming` class — this is a forward-looking hook). */
+.chat-message-container.is-streaming .chattext {
+  box-shadow: inset 0 0 0 1px var(--chat-streaming-color, var(--msg-streaming-border, var(--accent-press)));
+}
+
+/* Panel-in: subtle fade-up for view/panel transitions. From AlterRisu.
+   Transform+opacity only (GPU-friendly). Honors prefers-reduced-motion via
+   --dur-base falling to 0ms. */
+@keyframes panel-in {
+  from {
+    opacity: 0;
+    transform: translateY(6px);
+  }
+  to {
+    opacity: 1;
+    transform: none;
+  }
+}
+
+.rs-panel-in {
+  animation: panel-in var(--dur-base) var(--ease-out) backwards;
+}
+
+/* Streaming indicator pulse. */
+@keyframes streaming-pulse {
+  0%, 100% { opacity: 1; }
+  50% { opacity: 0.4; }
+}
+
+.streaming-dot {
+  animation: streaming-pulse 1.2s var(--ease-out) infinite;
+}
+
+/* Smooth scrolling for chat containers without forcing it everywhere. */
+.chat-scroll {
+  scroll-behavior: smooth;
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .chat-scroll {
+    scroll-behavior: auto;
+  }
+}
+
+/* GPU hint for animated overlays. */
+.gpu-layer {
+  will-change: transform, opacity;
+  transform: translateZ(0);
+  backface-visibility: hidden;
+}
+
+/* Avoid layout shift from lazy images by reserving space via aspect-ratio. */
+img {
+  max-width: 100%;
+  height: auto;
+}
+
+/* Reduce paint cost for large static backgrounds. */
+body,
+#app {
+  contain: paint;
+}
